# Local development only. Foundry injects these at runtime in production.
FOUNDRY_PROJECT_ENDPOINT="https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project>"
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5-mini"

# Set to 1 to force DefaultAzureCredential locally (uses `az login`).
LOCAL_DEV="1"
